{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "views/**/*.ejs"
    }
  },
  "rewrites": [
    { 
      "source": "/dashboard-pink", 
      "destination": "/index.html" 
    },
    { 
      "source": "/dashboard-blue", 
      "destination": "/index.html" 
    },
    { 
      "source": "/(.*)", 
      "destination": "/api/index.js" 
    }
  ]
}
