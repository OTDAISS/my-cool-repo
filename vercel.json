{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/dist/assets/$1" },
    { "src": "/dashboard-pink", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "index.js" }
  ],
  "functions": {
    "index.js": {
      "includeFiles": "views/**/*.ejs"
    }
  }
}
