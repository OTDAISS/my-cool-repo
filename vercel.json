{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "views/**/*.ejs"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1"
    },
    {
      "src": "/dashboard-pink",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard-blue",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
