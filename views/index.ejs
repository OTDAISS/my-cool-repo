<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <script async src="https://js.stripe.com/v3/buy-button.js"></script>
    <style>
        :root {
            --deep-blue: #003366;
            --bright-teal: #00ced1;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            background-color: #f4f9fc;
            color: var(--deep-blue);
        }
        header {
            background-color: white;
            padding: 40px 20px;
            text-align: center;
            border-bottom: 6px solid var(--bright-teal);
        }
        h1 {
            font-size: 3rem;
            margin: 0;
            color: var(--deep-blue);
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .tagline {
            font-style: italic;
            font-size: 1.2rem;
            color: #555;
            margin-top: 10px;
        }
        main {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 30px;
            padding: 50px 20px;
        }
        .card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 30px;
            width: 350px;
            text-align: center;
            transition: transform 0.3s ease;
        }
        .card:hover { transform: translateY(-10px); }
        .pink-card { border-top: 10px solid #ff99cc; }
        .blue-card { border-top: 10px solid var(--bright-teal); }
        
        .btn-pink {
            display: inline-block;
            margin-top: 20px;
            padding: 15px 35px;
            border-radius: 50px;
            background-color: #ff99cc;
            color: white;
            text-decoration: none;
            font-weight: bold;
        }

        footer {
            text-align: center;
            padding: 40px;
            font-size: 0.9rem;
            color: #888;
        }
    </style>
</head>
<body>

    <header>
        <h1>AI Surfer Survivor</h1>
        <p class="tagline">Forge Ahead. Ride the AI Wave. Today is the Day.</p>
    </header>

    <main>
        <div class="card pink-card">
            <h2 style="color: #ff66b2;">Pink Tier</h2>
            <p>Start your journey as an AI Survivor. Access our free community and core training modules.</p>
            <a href="/dashboard" class="btn btn-pink">Enter Dashboard</a>
        </div>

        <div class="card blue-card">
            <h2>Blue Tier</h2>
            <p>Unlock advanced full-stack challenges, automation tools, and the pro survival kit.</p>
            
            <stripe-buy-button
              buy-button-id="buy_btn_1Sz2KJFXSpOayG0A9oGMNKzp"
              publishable-key="pk_test_51SRcVjFXSpOayG0AILUwALLW7AWB4eFPHvSKhWmPBxClIcKJPVU69d3weKl8BPQ5UPx0Dbn6GKP17DAd9VHJIsPk00ehvxEgbX"
            >
            </stripe-buy-button>
        </div>
    </main>

    <footer>
        &copy; <%= new Date().getFullYear() %> Ocean Tide | Launch Day Live
    </footer>

</body>
</html>
