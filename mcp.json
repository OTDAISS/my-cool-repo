{
	"servers": {
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:0.30.3"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.30.3"
		},
		"io.github.ChromeDevTools/chrome-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--registry",
				"https://registry.npmjs.org",
				"chrome-devtools-mcp@0.17.1"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.17.1"
		},
		"com.stripe/mcp": {
			"type": "http",
			"url": "https://mcp.stripe.com",
			"gallery": "https://api.mcp.github.com",
			"version": "0.2.4"
		},
		"com.qualityclouds/mcp-server-qualityclouds": {
			"type": "http",
			"url": "https://mcp.qualityclouds.com/mcp",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.2"
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	]
}
